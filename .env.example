# MariaDB — main logger user (read-write)
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=mqttlogger
MYSQL_USER=mqttlogger
MYSQL_PASSWORD=

# MariaDB — companion monitor read-only user (SELECT-only on sensorreadings)
# Create on sietchtabr before first deploy (see ADR-009):
#   CREATE USER 'monitor_ro'@'%' IDENTIFIED BY '<password>';
#   GRANT SELECT ON mqttlogger.sensorreadings TO 'monitor_ro'@'%';
#   FLUSH PRIVILEGES;
MONITOR_DB_USER=monitor_ro
MONITOR_DB_PASSWORD=
