# mqttlogger environment variables
# Copy to .env on sietchtabr and fill in real values.
# Never commit .env to version control.

# --- MariaDB ---
MYSQL_ROOT_PASSWORD=<root_password>
MYSQL_DATABASE=<database_name>
MYSQL_USER=<mqttlogger_write_user>
MYSQL_PASSWORD=<mqttlogger_write_password>

# --- Grafana (OPT-A dashboard) ---
# Create the read-only DB user before starting Grafana (run once inside mariadb container):
#   CREATE USER '<grafana_ro_user>'@'%' IDENTIFIED BY '<grafana_ro_password>';
#   GRANT SELECT ON <database_name>.sensorreadings TO '<grafana_ro_user>'@'%';
#   FLUSH PRIVILEGES;
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<grafana_admin_password>
GRAFANA_DB_USER=grafana
GRAFANA_DB_PASSWORD=<grafana_db_password>
